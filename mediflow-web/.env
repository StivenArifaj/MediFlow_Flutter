# MediFlow Web Dashboard - Environment Configuration

# Firebase Configuration
# Replace these values with your actual Firebase project credentials
# You can find these in your google-services.json file

FIREBASE_PROJECT_ID=mediflow-xxxxx
FIREBASE_API_KEY=YOUR_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=mediflow-xxxxx.firebaseapp.com
FIREBASE_DATABASE_URL=https://mediflow-xxxxx.firebaseio.com
FIREBASE_STORAGE_BUCKET=mediflow-xxxxx.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# App Configuration
APP_NAME=MediFlow
APP_ENV=local
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Prishtina

# Database (optional - for future use with MySQL sync)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mediflow
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_LIFETIME=3600